{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonexis.local/schema/dataset_schema.json",
  "title": "Sonexis conversational dataset record",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "pipeline_version",
    "model_versions",
    "config_hash",
    "num_speakers",
    "total_duration_sec",
    "total_speech_duration_sec",
    "dominant_language",
    "language_distribution",
    "generated_at",
    "input_mode",
    "session_name",
    "metadata",
    "audio_metadata",
    "annotations",
    "dataset_purpose",
    "dataset_products",
    "quality_targets",
    "quality_metrics",
    "accuracy_gate",
    "human_review",
    "code_switch",
    "transcript",
    "transcript_candidates",
    "consensus",
    "routing_decision",
    "timestamp_method",
    "timestamp_confidence",
    "timestamp_refinement",
    "tts_suitability",
    "delivery_status",
    "review_artifacts",
    "speaker_segmentation",
    "validation",
    "processing",
    "premium_processing"
  ],
  "additionalProperties": true,
  "$defs": {
    "wrapped_field": {
      "type": "object",
      "required": ["value", "confidence", "source"],
      "additionalProperties": true,
      "properties": {
        "value": {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source": {"type": "string"}
      }
    },
    "measured_field": {
      "allOf": [
        {"$ref": "#/$defs/wrapped_field"},
        {
          "type": "object",
          "required": ["method"],
          "properties": {
            "method": {"type": "string"}
          }
        }
      ]
    },
    "speaker_metadata": {
      "type": "object",
      "required": ["speaker_id", "accent", "region", "dialect"],
      "additionalProperties": true,
      "properties": {
        "speaker_id": {"type": "string"},
        "accent": {"$ref": "#/$defs/wrapped_field"},
        "region": {"$ref": "#/$defs/wrapped_field"},
        "dialect": {"$ref": "#/$defs/wrapped_field"}
      }
    },
    "audio_metadata": {
      "type": "object",
      "required": [
        "sample_rate_hz",
        "processed_sample_rate_hz",
        "channels",
        "effective_bandwidth_hz",
        "lufs"
      ],
      "additionalProperties": true,
      "properties": {
        "sample_rate_hz": {"type": "integer", "minimum": 1},
        "processed_sample_rate_hz": {"type": "integer", "minimum": 1},
        "bit_depth": {"type": ["integer", "null"], "minimum": 1},
        "channels": {"type": "integer", "minimum": 1},
        "codec": {"type": ["string", "null"]},
        "container_format": {"type": ["string", "null"]},
        "effective_bandwidth_hz": {"$ref": "#/$defs/measured_field"},
        "lufs": {"$ref": "#/$defs/measured_field"}
      }
    }
  },
  "properties": {
    "schema_version": {"type": "string"},
    "session_id": {"type": "string"},
    "pipeline_version": {"type": "string"},
    "pipeline_record_version": {"type": "string"},
    "model_versions": {"type": "object", "additionalProperties": true},
    "config_hash": {"type": "string"},
    "num_speakers": {"type": "integer", "minimum": 0},
    "total_duration_sec": {"type": "number", "minimum": 0},
    "total_speech_duration_sec": {"type": "number", "minimum": 0},
    "dominant_language": {"type": "string"},
    "language_distribution": {
      "type": "object",
      "additionalProperties": {"type": "integer"}
    },
    "generated_at": {"type": "string"},
    "input_mode": {"type": "string"},
    "session_name": {"type": "string"},
    "input_alignment": {"type": "object", "additionalProperties": true},
    "mono_mix": {"type": "object", "additionalProperties": true},
    "audio_metadata": {"$ref": "#/$defs/audio_metadata"},
    "annotations": {
      "type": "object",
      "required": [
        "transcript_available",
        "speaker_turns_available",
        "timestamps_available",
        "language_segments_available",
        "monologue_available",
        "validation_report_available"
      ],
      "additionalProperties": true,
      "properties": {
        "transcript_available": {"type": "boolean"},
        "speaker_turns_available": {"type": "boolean"},
        "timestamps_available": {"type": "boolean"},
        "language_segments_available": {"type": "boolean"},
        "monologue_available": {"type": "boolean"},
        "validation_report_available": {"type": "boolean"}
      }
    },
    "dataset_purpose": {
      "type": "object",
      "required": ["primary", "secondary", "not_recommended_for"],
      "additionalProperties": true,
      "properties": {
        "primary": {"type": "array", "items": {"type": "string"}},
        "secondary": {"type": "array", "items": {"type": "string"}},
        "not_recommended_for": {"type": "array", "items": {"type": "string"}}
      }
    },
    "quality_targets": {
      "type": "object",
      "required": [
        "word_accuracy_target",
        "timestamp_accuracy_target",
        "code_switch_accuracy_target",
        "human_review_required"
      ],
      "additionalProperties": true,
      "properties": {
        "word_accuracy_target": {"type": "number", "minimum": 0, "maximum": 1},
        "timestamp_accuracy_target": {"type": "number", "minimum": 0, "maximum": 1},
        "code_switch_accuracy_target": {"type": "number", "minimum": 0, "maximum": 1},
        "human_review_required": {"type": "boolean"}
      }
    },
    "quality_metrics": {
      "type": "object",
      "required": [
        "estimated_word_accuracy",
        "estimated_timestamp_accuracy",
        "estimated_code_switch_accuracy",
        "benchmark_evaluated",
        "human_review_completed"
      ],
      "additionalProperties": true,
      "properties": {
        "estimated_word_accuracy": {"type": ["number", "null"]},
        "estimated_timestamp_accuracy": {"type": ["number", "null"]},
        "estimated_code_switch_accuracy": {"type": ["number", "null"]},
        "benchmark_evaluated": {"type": "boolean"},
        "human_review_completed": {"type": "boolean"}
      }
    },
    "human_review": {
      "type": "object",
      "required": ["required", "status", "review_stage", "priority", "reviewer_id", "notes"],
      "additionalProperties": true,
      "properties": {
        "required": {"type": "boolean"},
        "status": {"type": "string"},
        "review_stage": {"type": "string"},
        "priority": {
          "type": "object",
          "required": ["level", "score", "reasons"],
          "additionalProperties": true,
          "properties": {
            "level": {"type": "string"},
            "score": {"type": "number", "minimum": 0},
            "reasons": {"type": "array", "items": {"type": "string"}}
          }
        },
        "reviewer_id": {"type": ["string", "null"]},
        "notes": {"type": ["string", "null"]}
      }
    },
    "code_switch": {
      "type": "object",
      "required": [
        "detected",
        "dominant_languages",
        "switch_count",
        "switch_patterns",
        "review_required"
      ],
      "additionalProperties": true,
      "properties": {
        "detected": {"type": "boolean"},
        "dominant_languages": {"type": "array", "items": {"type": "string"}},
        "switch_count": {"type": "integer", "minimum": 0},
        "switch_patterns": {"type": "array", "items": {"type": "string"}},
        "review_required": {"type": "boolean"}
      }
    },
    "metadata": {
      "type": "object",
      "required": ["audio", "language", "speakers", "conversation", "interaction"],
      "additionalProperties": true,
      "properties": {
        "audio": {"$ref": "#/$defs/audio_metadata"},
        "language": {"type": "object", "additionalProperties": true},
        "speakers": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/speaker_metadata"}
        },
        "conversation": {
          "type": "object",
          "required": ["domain"],
          "additionalProperties": true,
          "properties": {
            "domain": {"$ref": "#/$defs/wrapped_field"}
          }
        },
        "interaction": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "turn_count": {"type": "integer", "minimum": 0},
            "interruptions": {"type": "integer", "minimum": 0},
            "overlap_duration": {"type": "number", "minimum": 0},
            "dominance": {"type": "object", "additionalProperties": true}
          }
        }
      }
    },
    "transcript": {
      "type": "object",
      "required": ["raw", "segments"],
      "additionalProperties": true,
      "properties": {
        "raw": {"type": "string"},
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "segment_id",
              "audio_filepath",
              "start",
              "end",
              "duration",
              "speaker_id",
              "language",
              "text",
              "text_normalized",
              "sample_rate",
              "missing_fields",
              "snr_band",
              "overlap",
              "confidence_band",
              "matrix_language",
              "switch_points",
              "cs_density",
              "punctuation_applied"
            ],
            "additionalProperties": true,
            "properties": {
              "segment_id": {"type": "string", "minLength": 1},
              "audio_filepath": {"type": "string"},
              "start": {"type": "number", "minimum": 0},
              "end": {"type": "number", "minimum": 0},
              "duration": {"type": "number", "minimum": 0},
              "speaker_id": {"type": "string"},
              "language": {"type": "string"},
              "text": {"type": "string"},
              "text_normalized": {"type": "string"},
              "sample_rate": {"type": "integer", "minimum": 1},
              "missing_fields": {"type": "array", "items": {"type": "string"}},
              "snr_db": {"type": ["number", "null"]},
              "snr_band": {"type": ["string", "null"]},
              "snr_reason": {"type": ["string", "null"]},
              "snr_source": {"type": ["string", "null"]},
              "clipping_ratio": {"type": "number", "minimum": 0},
              "overlap": {"type": "boolean"},
              "confidence": {"type": ["number", "null"]},
              "confidence_band": {"type": ["string", "null"]},
              "confidence_band_absolute": {"type": ["string", "null"]},
              "confidence_band_relative": {"type": ["string", "null"]},
              "confidence_reasons": {"type": "array", "items": {"type": "string"}},
              "confidence_components": {"type": "object", "additionalProperties": true},
              "quality_tier": {"type": "string"},
              "tier_reasons": {"type": "array", "items": {"type": "string"}},
              "flagged_for_review": {"type": "boolean"},
              "review_reasons": {"type": "array", "items": {"type": "string"}}
              ,
              "punctuation_applied": {"type": "boolean"},
              "punct_skipped": {"type": ["string", "null"]},
              "matrix_language": {"type": "string"},
              "switch_points": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["word_idx", "from_lang", "to_lang", "switch_type"],
                  "additionalProperties": true,
                  "properties": {
                    "word_idx": {"type": "integer", "minimum": 0},
                    "from_lang": {"type": "string"},
                    "to_lang": {"type": "string"},
                    "switch_type": {"type": "string"}
                  }
                }
              },
              "cs_density": {"type": "number", "minimum": 0}
            }
          }
        }
      }
    },
    "transcript_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["engine", "provider", "paid_api", "transcript", "timing_source", "normalisation_notes"],
        "additionalProperties": true,
        "properties": {
          "engine": {"type": "string"},
          "provider": {"type": "string"},
          "paid_api": {"type": "boolean"},
          "transcript": {"type": "object", "additionalProperties": true},
          "timing_source": {"type": "string"},
          "normalisation_notes": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "routing_decision": {
      "type": "object",
      "required": [
        "difficulty_score",
        "escalated_to_paid",
        "reasons",
        "engines_attempted",
        "engines_skipped"
      ],
      "additionalProperties": true,
      "properties": {
        "difficulty_score": {"type": "number", "minimum": 0, "maximum": 1},
        "escalated_to_paid": {"type": "boolean"},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "engines_attempted": {"type": "array", "items": {"type": "string"}},
        "engines_skipped": {"type": "array", "items": {"type": "string"}}
      }
    },
    "timestamp_method": {"type": ["string", "null"]},
    "timestamp_confidence": {"type": ["number", "null"]},
    "timestamp_refinement": {
      "type": "object",
      "required": [
        "word_timestamps_available",
        "segment_timestamps_available",
        "refinement_applied",
        "synthetic_word_timestamps",
        "timing_quality",
        "notes"
      ],
      "additionalProperties": true,
      "properties": {
        "word_timestamps_available": {"type": "boolean"},
        "segment_timestamps_available": {"type": "boolean"},
        "refinement_applied": {"type": "boolean"},
        "synthetic_word_timestamps": {"type": "boolean"},
        "timing_quality": {"type": "string"},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "tts_suitability": {
      "type": "object",
      "required": ["eligible", "reasons", "confidence"],
      "additionalProperties": true,
      "properties": {
        "eligible": {"type": "boolean"},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "dataset_products": {
      "type": "array",
      "items": {"type": "string"}
    },
    "speaker_segmentation": {"type": "array"},
    "validation": {
      "type": "object",
      "required": ["passed", "issue_count", "issues", "checks"],
      "additionalProperties": true,
      "properties": {
        "passed": {"type": "boolean"},
        "issue_count": {"type": "integer", "minimum": 0},
        "issues": {"type": "array"},
        "checks": {"type": "object", "additionalProperties": true}
      }
    },
    "processing": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "offline_mode": {"type": "boolean"},
        "random_seed": {"type": "integer"}
      }
    },
    "premium_processing": {
      "type": "object",
      "required": [
        "pipeline_mode",
        "paid_api_used",
        "engines_used",
        "consensus_applied",
        "timestamp_refinement_applied",
        "human_review_required"
      ],
      "additionalProperties": true,
      "properties": {
        "pipeline_mode": {"type": "string"},
        "paid_api_used": {"type": "boolean"},
        "engines_used": {"type": "array", "items": {"type": "string"}},
        "consensus_applied": {"type": "boolean"},
        "timestamp_refinement_applied": {"type": "boolean"},
        "human_review_required": {"type": "boolean"}
      }
    }
  }
}
