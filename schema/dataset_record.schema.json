{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonexis.local/schema/dataset_record.schema.json",
  "title": "Sonexis dataset record",
  "type": "object",
  "required": [
    "schema_version",
    "session_name",
    "session_id",
    "input_mode",
    "pipeline_mode",
    "transcript",
    "metadata",
    "validation",
    "accuracy_gate",
    "human_review",
    "delivery_status"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "3.0.0"},
    "session_name": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "input_mode": {"type": "string", "minLength": 1},
    "pipeline_mode": {"type": "string"},
    "metadata": {"type": "object"},
    "validation": {
      "type": "object",
      "required": ["passed"],
      "additionalProperties": true,
      "properties": {
        "passed": {"type": "boolean"}
      }
    },
    "accuracy_gate": {
      "type": "object",
      "required": [
        "passed",
        "human_review_required",
        "human_review_completed",
        "human_review_required_for_delivery"
      ],
      "additionalProperties": true,
      "properties": {
        "target_word_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "estimated_word_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "verified_word_accuracy": {
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ]
        },
        "target_speaker_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "estimated_speaker_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "verified_speaker_accuracy": {
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ]
        },
        "target_timestamp_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "estimated_timestamp_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "verified_timestamp_accuracy": {
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ]
        },
        "target_code_switch_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "estimated_code_switch_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
        "verified_code_switch_accuracy": {
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ]
        },
        "estimated": {"type": "boolean"},
        "verified_accuracy": {"type": "boolean"},
        "passed": {"type": "boolean"},
        "human_review_required": {"type": "boolean"},
        "human_review_completed": {"type": "boolean"},
        "human_review_required_for_delivery": {"type": "boolean"},
        "word_accuracy_basis": {"type": "string"},
        "asr_accuracy_basis": {"type": "string"},
        "reviewed_delivery_target_met": {"type": "boolean"},
        "measured_word_accuracy_available": {"type": "boolean"},
        "measured_word_accuracy": {
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ]
        },
        "reviewed_delivery_confidence": {
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ]
        },
        "reasons": {"type": "array", "items": {"type": "string"}}
      }
    },
    "human_review": {
      "type": "object",
      "required": ["required", "status"],
      "additionalProperties": true,
      "properties": {
        "required": {"type": "boolean"},
        "status": {"type": "string"}
      }
    },
    "delivery_status": {
      "type": "object",
      "required": ["stage", "approved_for_client_delivery"],
      "additionalProperties": true,
      "properties": {
        "stage": {"enum": ["review_required", "reviewed", "approved", "rejected"]},
        "approved_for_client_delivery": {"type": "boolean"},
        "reason": {"type": ["string", "null"]}
      }
    },
    "transcript": {
      "type": "object",
      "required": ["raw", "segments"],
      "additionalProperties": true,
      "properties": {
        "raw": {"type": "string"},
        "normalised": {"type": "string"},
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["segment_id", "start", "end", "speaker_id", "text", "sample_rate"],
            "additionalProperties": true,
            "properties": {
              "segment_id": {"type": "string", "minLength": 1},
              "start": {"type": "number", "minimum": 0},
              "end": {"type": "number"},
              "duration": {"type": "number"},
              "speaker_id": {"type": "string", "minLength": 1},
              "text": {"type": "string"},
              "text_normalized": {"type": "string"},
              "language": {"type": "string"},
              "sample_rate": {"type": "integer", "minimum": 1},
              "missing_fields": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "transcript_candidates": {"type": "array"},
    "consensus": {"type": "object"},
    "review_artifacts": {"type": "object"}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "pipeline_mode": {"const": "premium_accuracy"}
        },
        "required": ["pipeline_mode"]
      },
      "then": {
        "required": [
          "transcript_candidates",
          "consensus",
          "review_artifacts",
          "accuracy_gate",
          "delivery_status"
        ]
      }
    }
  ]
}
