{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SonexisDatasetRecord",
  "description": "Schema for one session record produced by the Sonexis conversational-audio pipeline (v3.0.0).",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "input_mode",
    "session_name",
    "file",
    "metadata",
    "transcript",
    "timeline",
    "conversation_transcript",
    "validation"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semantic version of the output schema (e.g. \"3.0.0\")."
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp when this record was generated."
    },
    "input_mode": {
      "type": "string",
      "enum": ["mono", "speaker_pair", "stereo"],
      "description": "How the source audio was supplied."
    },
    "session_name": {
      "type": "string",
      "minLength": 1
    },
    "file": {
      "$ref": "#/definitions/FileDescriptor"
    },
    "source_files": {
      "type": "array",
      "items": { "$ref": "#/definitions/FileDescriptor" }
    },
    "metadata": {
      "type": "object",
      "required": ["audio", "language", "speakers", "conversation"],
      "properties": {
        "audio": {
          "type": "object",
          "required": ["duration_s", "sample_rate"],
          "properties": {
            "duration_s":            { "type": "number", "minimum": 0 },
            "sample_rate":           { "type": "integer", "minimum": 1 },
            "rms_db":                { "type": "number" },
            "snr_db_estimate":       { "type": "number" },
            "rt60_s_estimate":       { "type": "number", "minimum": 0 },
            "spectral_centroid_khz": { "type": "number", "minimum": 0 },
            "environment": {
              "$ref": "#/definitions/ConfidenceField"
            },
            "noise_level": {
              "$ref": "#/definitions/ConfidenceField"
            },
            "device_estimate": {
              "$ref": "#/definitions/ConfidenceField"
            }
          }
        },
        "language": {
          "type": "object",
          "required": ["primary_language", "confidence", "code_switching"],
          "properties": {
            "primary_language":    { "type": "string" },
            "confidence":          { "type": "number", "minimum": 0, "maximum": 1 },
            "dominant_language":   { "type": "string" },
            "code_switching":      { "type": "boolean" },
            "multilingual_flag":   { "type": "boolean" },
            "switching_frequency": { "type": "number", "minimum": 0 },
            "switching_score":     { "type": "number", "minimum": 0, "maximum": 1 },
            "switching_pattern": {
              "type": "object",
              "description": "Directional transition counts, e.g. {\"hi→en\": 3, \"en→hi\": 2}.",
              "additionalProperties": { "type": "integer", "minimum": 0 }
            },
            "scripts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "language_segments": {
              "type": "array",
              "items": { "$ref": "#/definitions/LanguageSegment" }
            },
            "per_segment": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["text", "language"],
                "properties": {
                  "text":     { "type": "string" },
                  "language": { "type": "string" }
                }
              }
            },
            "method": { "type": "string" }
          }
        },
        "speakers": {
          "type": "object",
          "description": "Per-speaker metadata, keyed by speaker ID (e.g. \"SPEAKER_00\").",
          "additionalProperties": {
            "$ref": "#/definitions/SpeakerMeta"
          }
        },
        "conversation": {
          "type": "object",
          "required": ["turn_count", "speaker_count"],
          "properties": {
            "turn_count":           { "type": "integer", "minimum": 0 },
            "speaker_count":        { "type": "integer", "minimum": 0 },
            "avg_turn_length_s":    { "type": "number", "minimum": 0 },
            "total_speech_time_s":  { "type": "number", "minimum": 0 },
            "topic_keywords": {
              "type": "array",
              "items": { "type": "string" }
            },
            "intents": {
              "type": "array",
              "items": { "type": "string" }
            },
            "quality": { "type": "object" }
          }
        },
        "interaction": {
          "type": "object",
          "properties": {
            "interruption_count":    { "type": "integer", "minimum": 0 },
            "overlap_duration_s":    { "type": "number", "minimum": 0 },
            "overlap_segments":      { "type": "integer", "minimum": 0 },
            "response_latency":      { "type": "object" },
            "turn_switch_frequency": { "type": "number", "minimum": 0 },
            "dominance":             { "type": "object" },
            "dominant_speaker":      { "type": ["string", "null"] },
            "engagement_score":      { "type": "number", "minimum": 0, "maximum": 1 },
            "total_turns":           { "type": "integer", "minimum": 0 },
            "conversation_duration_s":{ "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "transcript": {
      "type": "object",
      "required": ["raw", "language", "duration_s", "segments"],
      "properties": {
        "raw":                  { "type": "string" },
        "normalised":           { "type": "string" },
        "language":             { "type": "string" },
        "language_probability": { "type": "number", "minimum": 0, "maximum": 1 },
        "duration_s":           { "type": "number", "minimum": 0 },
        "segments": {
          "type": "array",
          "items": { "$ref": "#/definitions/TranscriptSegment" }
        }
      }
    },
    "timeline": {
      "type": "array",
      "description": "Flat sorted list of speaker turns.",
      "items": { "$ref": "#/definitions/TimelineEntry" }
    },
    "speaker_transcripts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "conversation_transcript": {
      "type": "array",
      "items": { "$ref": "#/definitions/ConversationEntry" }
    },
    "speaker_segmentation": {
      "type": "array",
      "items": { "$ref": "#/definitions/SpeakerTurn" }
    },
    "monologues": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "null" },
          { "$ref": "#/definitions/MonologueSample" }
        ]
      }
    },
    "monologue_sample": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/definitions/MonologueSample" }
      ]
    },
    "quality": { "type": "object" },
    "validation": {
      "type": "object",
      "required": ["passed", "issue_count", "issues"],
      "properties": {
        "passed":      { "type": "boolean" },
        "issue_count": { "type": "integer", "minimum": 0 },
        "issues": {
          "type": "array",
          "items": { "$ref": "#/definitions/ValidationIssue" }
        },
        "checks": { "type": "object" }
      }
    },
    "processing": { "type": "object" },
    "artifacts":  { "type": "object" }
  },

  "definitions": {
    "FileDescriptor": {
      "type": "object",
      "required": ["path", "name"],
      "properties": {
        "path":       { "type": "string" },
        "name":       { "type": "string" },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "sha1":       { "type": ["string", "null"] }
      }
    },
    "ConfidenceField": {
      "type": "object",
      "required": ["value", "confidence"],
      "properties": {
        "value":      { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "method":     { "type": "string" }
      }
    },
    "LanguageSegment": {
      "type": "object",
      "required": ["start", "end", "language"],
      "properties": {
        "start":      { "type": "number", "minimum": 0 },
        "end":        { "type": "number", "minimum": 0 },
        "language":   { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "SpeakerMeta": {
      "type": "object",
      "properties": {
        "label":                   { "type": "string" },
        "total_speaking_time_s":   { "type": "number", "minimum": 0 },
        "word_count":              { "type": "integer", "minimum": 0 },
        "wpm":                     { "type": "number", "minimum": 0 },
        "pause_rate":              { "type": "number", "minimum": 0 },
        "pause_frequency_per_min": { "type": "number", "minimum": 0 },
        "filler_ratio":            { "type": "number", "minimum": 0 },
        "speaking_style":  { "$ref": "#/definitions/ConfidenceField" },
        "formality":       { "$ref": "#/definitions/ConfidenceField" },
        "accent":          { "$ref": "#/definitions/ConfidenceField" },
        "turn_count":      { "type": "integer", "minimum": 0 },
        "speech_ratio":    { "type": ["number", "null"], "minimum": 0 },
        "overlap_ratio":   { "type": "number", "minimum": 0 },
        "dominance_score": { "type": "number", "minimum": 0 }
      }
    },
    "TranscriptSegment": {
      "type": "object",
      "required": ["start", "end", "text"],
      "properties": {
        "start":         { "type": "number", "minimum": 0 },
        "end":           { "type": "number", "minimum": 0 },
        "text":          { "type": "string" },
        "language":      { "type": ["string", "null"] },
        "quality_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "TimelineEntry": {
      "type": "object",
      "required": ["speaker", "start", "end"],
      "properties": {
        "speaker":    { "type": "string" },
        "label":      { "type": "string" },
        "start":      { "type": "number", "minimum": 0 },
        "end":        { "type": "number", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "ConversationEntry": {
      "type": "object",
      "required": ["speaker", "start", "end", "text"],
      "properties": {
        "speaker":       { "type": "string" },
        "label":         { "type": "string" },
        "start":         { "type": "number", "minimum": 0 },
        "end":           { "type": "number", "minimum": 0 },
        "text":          { "type": "string" },
        "language":      { "type": ["string", "null"] },
        "quality_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "SpeakerTurn": {
      "type": "object",
      "required": ["speaker", "start", "end"],
      "properties": {
        "speaker":    { "type": "string" },
        "start":      { "type": "number", "minimum": 0 },
        "end":        { "type": "number", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "MonologueSample": {
      "type": "object",
      "required": ["speaker", "start", "end", "transcript"],
      "properties": {
        "speaker":           { "type": "string" },
        "start":             { "type": "number", "minimum": 0 },
        "end":               { "type": "number", "minimum": 0 },
        "duration_s":        { "type": "number", "minimum": 0 },
        "transcript":        { "type": "string" },
        "words":             { "type": "array" },
        "in_range":          { "type": "boolean" },
        "quality_score":     { "type": "number", "minimum": 0, "maximum": 1 },
        "silence_ratio":     { "type": "number", "minimum": 0, "maximum": 1 },
        "interruption_free": { "type": "boolean" }
      }
    },
    "ValidationIssue": {
      "type": "object",
      "required": ["severity", "code", "message"],
      "properties": {
        "severity":   { "type": "string", "enum": ["error", "warning", "info"] },
        "code":       { "type": "string" },
        "message":    { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "details":    { "type": "object" }
      }
    }
  }
}
